{
  "name": "@libraz/mysql-event-stream",
  "version": "1.4.0",
  "description": "MySQL 8.4+ / MariaDB 10.11+ CDC engine - Node.js binding (native N-API)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "build/Release/*.node"
  ],
  "scripts": {
    "build:native": "cmake-js compile",
    "build": "npm run build:native && tsc",
    "check": "biome check src/ tests/",
    "check:fix": "biome check --write src/ tests/",
    "test": "vitest run",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run check && npm run test",
    "prepack": "cp README.md .readme-backup && cp README.npm.md README.md",
    "postpack": "mv .readme-backup README.md"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/libraz/mysql-event-stream.git",
    "directory": "bindings/node"
  },
  "homepage": "https://github.com/libraz/mysql-event-stream",
  "bugs": "https://github.com/libraz/mysql-event-stream/issues",
  "keywords": [
    "mysql",
    "mariadb",
    "cdc",
    "binlog",
    "replication",
    "change-data-capture",
    "napi"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.9.1",
  "volta": {
    "node": "22.16.0",
    "yarn": "4.9.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "4",
    "cmake-js": "^8.0.0",
    "mysql2": "^3.22.5",
    "node-addon-api": "^8.8.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  }
}
